{% extends 'base.html.twig' %}

{% block title %}course{% endblock %}

{% block body %}
    <h1>course</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ cour.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ cour.name }}</td>
            </tr>
            <tr>
                <th>Level</th>
                <td>{{ cour.level }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ cour.createdAt ? cour.createdAt|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ cour.updatedAt ? cour.updatedAt|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_appli_course_index') }}">back to list</a>

    <a href="{{ path('app_appli_course_edit', {'id': cour.id}) }}">edit</a>

    {{ include('appli/course/_delete_form.html.twig') }}
{% endblock %}
