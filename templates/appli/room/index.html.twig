{% extends 'base.html.twig' %}

{% block title %}room index{% endblock %}

{% block main %}
    <h1>room index</h1>

    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>MaxPlace</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for room in rooms %}
            <tr>
                <td>{{ room.id }}</td>
                <td>{{ room.name }}</td>
                <td>{{ room.maxPlace }}</td>
                <td>{{ room.createdAt ? room.createdAt|date('Y-m-d') : '' }}</td>
                <td>{{ room.updatedAt ? room.updatedAt|date('Y-m-d') : '' }}</td>
                <td>
                    <a href="{{ path('op_appli_room_show', {'id': room.id}) }}">show</a>
                    <a href="{{ path('op_appli_room_edit', {'id': room.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('op_appli_room_new') }}">Create new</a>
{% endblock %}
