{% extends 'base.html.twig' %}

{% block title %}room{% endblock %}

{% block body %}
    <h1>room</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ room.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ room.name }}</td>
            </tr>
            <tr>
                <th>MaxPlace</th>
                <td>{{ room.maxPlace }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ room.createdAt ? room.createdAt|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ room.updatedAt ? room.updatedAt|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_appli_room_index') }}">back to list</a>

    <a href="{{ path('app_appli_room_edit', {'id': room.id}) }}">edit</a>

    {{ include('appli/room/_delete_form.html.twig') }}
{% endblock %}
