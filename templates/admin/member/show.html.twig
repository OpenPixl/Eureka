{% extends 'base.html.twig' %}

{% block title %}Member{% endblock %}

{% block body %}
    <h1>Member</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ member.id }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ member.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ member.roles ? member.roles|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ member.password }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ member.firstName }}</td>
            </tr>
            <tr>
                <th>LastName</th>
                <td>{{ member.lastName }}</td>
            </tr>
            <tr>
                <th>Adress</th>
                <td>{{ member.adress }}</td>
            </tr>
            <tr>
                <th>Complement</th>
                <td>{{ member.complement }}</td>
            </tr>
            <tr>
                <th>Zipcode</th>
                <td>{{ member.zipcode }}</td>
            </tr>
            <tr>
                <th>City</th>
                <td>{{ member.city }}</td>
            </tr>
            <tr>
                <th>Mobile</th>
                <td>{{ member.Mobile }}</td>
            </tr>
            <tr>
                <th>Home</th>
                <td>{{ member.home }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ member.createdAt ? member.createdAt|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ member.updatedAt ? member.updatedAt|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_member_index') }}">back to list</a>

    <a href="{{ path('app_admin_member_edit', {'id': member.id}) }}">edit</a>

    {{ include('admin/member/_delete_form.html.twig') }}
{% endblock %}
