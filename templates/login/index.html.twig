{% extends 'login.html.twig' %}

{% block title %}Hello LoginController!{% endblock %}

{% block main %}
    <div class="row" id="blockLogin">

        <div class="col-12 d-flex justify-content-center mt-3 mt-3">
            <img src="{{ asset('images/svg/LogoIntro.svg') }}" class="img-fluid">
        </div>
        <div class="col-12 d-flex justify-content-center mt-3 mt-3">
            <img src="{{ asset('images/svg/TitleEuréka.svg') }}" class="img-fluid">
        </div>
        <div class="col-12 d-flex justify-content-center mt-4 mt-4">
            {% if error %}
                <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <form action="{{ path('op_public_security_login') }}" method="post">


                <div class="form-floating mb-3">
                    <input type="email" class="form-control" id="username" name="_username" value="{{ last_username }}"/>
                    <label for="floatingInput" class="tect-center">Utilisateur</label>
                </div>
                <div class="form-floating mb-3">
                    <input type="password"  name="_password" class="form-control" id="password" name="_password" value="{{ last_username }}"/>
                    <label for="floatingInput">Mot de passe</label>
                </div>


                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                {# If you want to control the URL the user is redirected to on success
        <input type="hidden" name="_target_path" value="/account"/> #}

                <button type="submit" class="btn btn-success w-100">login</button>
            </form>
        </div>

    </div>

{% endblock %}
